# FreeDownloader Environment Configuration
# Copy this file to .env and fill in the values

# ── Database (MySQL) ──────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=downloader_analytics

# ── Redis (Cache & Rate Limiting) ─────────────────────────────
# DB 0 is used for caching and rate limiting
REDIS_URL=redis://localhost:6379/0

# ── Celery (Background Tasks) ─────────────────────────────────
# DB 1 is used for the task broker and result backend
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── External APIs ─────────────────────────────────────────────
# Get a key from https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=AIzaSyDNhA-ILxYK98XO-K4H0mKoWB5Mog46K7o

# ── Proxy Configuration ───────────────────────────────────────
# Option 1: Comma-separated list of proxy URLs
# PROXY_LIST=socks5://user:pass@host:port,http://user:pass@host:port
PROXY_LIST=

# Option 2: Path to a file containing one proxy per line
PROXY_FILE=/root/FreeDownloader/proxies.txt

# ── Server Configuration (Production) ─────────────────────────
# Number of Gunicorn worker processes (usually CPU_CORES * 2)
GUNICORN_WORKERS=4

# Binding address for Gunicorn
GUNICORN_BIND=127.0.0.1:8000

# ── Debugging & Development ───────────────────────────────────
FLASK_DEBUG=true
FLASK_SKIP_DOTENV=false
